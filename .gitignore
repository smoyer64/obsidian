# Obsidian Workspace (prevents syncing open tabs/layout)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/workspace-mobile.json.bak
.obsidian/workspace.json.bak

# Local Plugin Settings (optional but recommended)
.obsidian/workspace-remotely-save.json
.obsidian/cache/
.obsidian/trash/
.obsidian/plugins/obsidian-git/.git_credentials_input

# System Files (if syncing from different OS)
.DS_Store
Thumbs.db

